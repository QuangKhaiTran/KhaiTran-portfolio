# Portfolio owner inputs — copy to .env.local and fill in before deploy.
# These override defaults in src/data/portfolio/site.ts at build time.

# VITE_PORTFOLIO_EMAIL=hello@yourdomain.com
# VITE_PORTFOLIO_CALENDLY=https://calendly.com/your-handle/30min
# VITE_PORTFOLIO_LINKEDIN=https://linkedin.com/in/your-profile
# VITE_PORTFOLIO_GITHUB=https://github.com/your-username
# VITE_PORTFOLIO_UPWORK=https://www.upwork.com/freelancers/~your-id
# VITE_PORTFOLIO_FIVERR=https://www.fiverr.com/your-username
# VITE_PORTFOLIO_CONTRA=https://contra.com/your-username
